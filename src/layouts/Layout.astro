---
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Доска позора чата — коллекция лучших и самых смешных высказываний участников, увековеченная навсегда."
    />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}/assets/favicon.svg`} type="image/svg+xml" />
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" preload />
  </head>
  <body class="bg-bg text-text min-h-screen m-0 overflow-x-hidden" style="background-color: #08080f; color: #f0f0f0;">
    <div class="bg-grid fixed inset-0 pointer-events-none"></div>
    <div class="glow fixed rounded-full w-[600px] h-[600px] bg-accent/5 -top-[250px] -left-[200px] animate-drift"></div>
    <div class="glow fixed rounded-full w-[500px] h-[500px] bg-purple/5 -bottom-[200px] -right-[200px] animate-drift [animation-delay:-6s]"></div>
    <slot />
    <footer class="relative z-10 text-center py-10 px-5 border-t border-white/10 text-text-dim">
      <p>Сделано с участниками чата</p>
      <p class="text-sm mt-1.5 italic text-text-muted">Автор идеи - Данила Митяшин</p>
    </footer>
  </body>
</html>
