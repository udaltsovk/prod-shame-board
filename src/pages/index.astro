---
import Layout from "../layouts/Layout.astro";
import shameData from "../data/shame.json";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface QuoteMessage {
  from: string;
  text?: string;
  image?: string | string[];
}

interface ShameEntry {
  id: number;
  telegram: string;
  description?: string;
  quote: string | string[] | QuoteMessage[];
  date: string;
  evidence: string;
  added_by: string;
  images?: string | string[];
}

const entries: ShameEntry[] = [...shameData].sort((a, b) => b.date.localeCompare(a.date));
const peopleCount = new Set(entries.map(e => e.telegram)).size;

const avatars = import.meta.glob<{ default: ImageMetadata }>("/public/avatars/*.{jpg,webp}");

/* ── яркие цвета для лучшего контраста ── */
const palette = [
  "#38bdf8", "#fb7185", "#facc15", "#4ade80", "#fb923c", "#c084fc",
  "#22d3ee", "#f472b6", "#818cf8", "#2dd4bf", "#fbbf24", "#a78bfa",
  "#f87171", "#e879f9", "#60a5fa", "#e2e8f0",
];

function hash(str: string) {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = str.charCodeAt(i) + ((h << 5) - h);
  }
  return Math.abs(h);
}

function colorFor(name: string) {
  return palette[hash(name) % palette.length];
}

function getAvatar(telegram: string) {
  const clean = telegram.replace("@", "");
  const webp = `/public/avatars/${clean}.webp`;
  const jpg = `/public/avatars/${clean}.jpg`;
  return avatars[webp] || avatars[jpg];
}

function getLetter(telegram: string) {
  const clean = telegram.replace("@", "");
  return clean.length > 0 ? clean[0].toUpperCase() : "?";
}
---

<Layout title="Доска позора">
  <header class="relative z-10 text-center pt-[60px] pb-[30px] px-5">
    <div class="logo text-[3.5em] animate-bounce-slow" role="img" aria-label="Трофей">🏆</div>
    <h1 class="text-[clamp(2em,7vw,3.5em)] font-extrabold tracking-tighter bg-gradient-to-br from-accent via-[#ff6b35] to-purple bg-clip-text text-transparent bg-[length:200%_200%]">
      Доска позора
    </h1>
    <p class="text-text-dim text-lg mt-2">Лучшие высказывания чата, увековеченные навсегда</p>
    <div class="flex justify-center gap-3 mt-7 flex-wrap">
      <a
        href="https://github.com/WatLon/prod-shame-board/issues/new?template=shame.yml"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 py-3.5 px-7 min-h-[48px] rounded-full font-semibold bg-accent text-white shadow-[0_4px_20px_rgba(225,29,72,0.25)] hover:-translate-y-0.5 hover:shadow-[0_6px_30px_rgba(225,29,72,0.25)] transition-all"
      >
        📛 Номинировать
      </a>
      <a
        href="https://github.com/WatLon/prod-shame-board"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 py-3.5 px-7 min-h-[48px] rounded-full font-semibold bg-card text-text border border-border hover:border-purple hover:-translate-y-0.5 transition-all"
        aria-label="Репозиторий проекта на GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path>
        </svg>
        GitHub
      </a>
    </div>
  </header>

  <div class="relative z-10 text-center py-4 px-5 font-mono text-text-dim" id="counter">
    <strong class="text-accent text-lg">{entries.length}</strong> позорных записей · <strong class="text-accent text-lg">{peopleCount}</strong> уникальных авторов
  </div>

  <div class="relative z-10 max-w-[700px] mx-auto mb-8 px-5">
    <input
      type="text"
      id="search"
      placeholder="🔍 Поиск по цитатам и людям..."
      class="w-full p-4 bg-card border border-border rounded-xl text-text outline-none focus:border-accent focus:shadow-[0_0_25px_rgba(225,29,72,0.25)] transition-all min-h-[48px]"
      aria-label="Поиск по цитатам и людям"
      autocomplete="off"
    />
  </div>

  <main class="relative z-10 max-w-[720px] mx-auto px-5 pb-[60px]" id="board">
    {
      entries.map((entry, i) => (
        <article
          class="entry opacity-0 translate-y-4 animate-fade-up bg-card border border-border rounded-xl mb-4.5 overflow-hidden hover:border-accent/20 hover:shadow-[0_10px_40px_rgba(0,0,0,0.35)] hover:-translate-y-0.5 transition-all duration-350"
          style={`animation-delay: ${i * 0.04}s`}
          data-searchable={JSON.stringify({
            telegram: entry.telegram.toLowerCase(),
            description: (entry.description || "").toLowerCase(),
            quote: JSON.stringify(entry.quote).toLowerCase(),
          })}
        >
          <div class="flex items-center gap-3 pt-5 px-[22px]">
            <div class="w-[42px] h-[42px] rounded-full shrink-0 relative overflow-hidden flex items-center justify-center font-extrabold text-white uppercase" style={`background: ${colorFor(entry.telegram)}`}>
              {getAvatar(entry.telegram) ? (
                <Image
                  src={getAvatar(entry.telegram)()}
                  alt=""
                  width={42}
                  height={42}
                  class="absolute inset-0 w-full h-full object-cover rounded-full z-10"
                  loading={i < 3 ? "eager" : "lazy"}
                  decoding="async"
                />
              ) : null}
              {getLetter(entry.telegram)}
            </div>
            <div class="font-mono font-medium truncate">
              <a
                href={`https://t.me/${entry.telegram.replace("@", "")}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text hover:text-accent transition-colors py-1 inline-block"
                aria-label={`Профиль ${entry.telegram} в Telegram`}
              >
                {entry.telegram}
              </a>
            </div>
          </div>

          {entry.description && <div class="pt-3.5 px-[22px] text-text-dim text-[0.95em] leading-relaxed">{entry.description}</div>}

          {entry.images && (
            <div class="pt-3.5 px-[22px] flex flex-wrap gap-2">
              {(Array.isArray(entry.images) ? entry.images : [entry.images]).map(url => (
                <img
                  src={url}
                  alt="Скриншот-подтверждение"
                  class="max-w-full max-h-[300px] rounded-xl border border-border cursor-pointer hover:border-accent hover:shadow-[0_4px_20px_rgba(0,0,0,0.4)] transition-all object-contain bg-white/5"
                  loading="lazy"
                  decoding="async"
                  onclick="window.open(this.src,'_blank')"
                />
              ))}
            </div>
          )}

          <div class="m-[14px_22px] p-[16px_20px] bg-quote-bg border-l-[3px] border-accent rounded-r-xl text-[1.05em] leading-[1.55] text-[#eee] relative">
            {typeof entry.quote === "string" ? (
              <span class="italic">
                {entry.quote.split("\n").map((line, idx, arr) => (
                  <Fragment key={idx}>
                    {line}
                    {idx < arr.length - 1 && <br />}
                  </Fragment>
                ))}
              </span>
            ) : Array.isArray(entry.quote) && typeof entry.quote[0] === "string" ? (
              (entry.quote as string[]).map((line, idx, arr) => (
                <div class={`py-[3px] ${idx > 0 ? "border-t border-white/5 mt-1.5 pt-1.5" : ""}`} key={idx}>
                  {line.split("\n").map((l, i, a) => (
                    <Fragment key={i}>
                      {l}
                      {i < a.length - 1 && <br />}
                    </Fragment>
                  ))}
                </div>
              ))
            ) : (
              (entry.quote as QuoteMessage[]).map((msg, idx) => (
                <div class={`py-[5px] ${idx > 0 ? "border-t border-white/5 mt-1.5 pt-1.5" : ""}`} key={idx}>
                  <span class="block font-mono font-semibold text-[0.85rem] mb-0.5" style={`color: ${colorFor(msg.from)}`}>
                    {msg.from}
                  </span>
                  {msg.image && (
                    <div class="flex flex-wrap gap-1.5 my-1.5">
                      {(Array.isArray(msg.image) ? msg.image : [msg.image]).map(url => (
                        <img
                          src={url}
                          alt={`Изображение от ${msg.from}`}
                          class="max-w-full max-h-[250px] rounded-lg border border-border cursor-pointer hover:border-accent hover:shadow-[0_4px_20px_rgba(0,0,0,0.4)] transition-all object-contain bg-white/5"
                          loading="lazy"
                          decoding="async"
                          onclick="window.open(this.src,'_blank')"
                        />
                      ))}
                    </div>
                  )}
                  {msg.text && (
                    <span class="text-[#eee]">
                      {msg.text.split("\n").map((line, i, a) => (
                        <Fragment key={i}>
                          {line}
                          {i < a.length - 1 && <br />}
                        </Fragment>
                      ))}
                    </span>
                  )}
                </div>
              ))
            )}
          </div>

          <div class="flex items-center pb-4 px-[22px]">
            <span class="text-text-muted text-sm font-mono">{entry.date}</span>
            {entry.evidence && (
              <a
                href={entry.evidence}
                target="_blank"
                rel="noopener noreferrer"
                class="ml-auto text-text-muted text-[0.9em] flex items-center gap-1 hover:text-accent transition-colors p-2"
                aria-label="Ссылка на сообщение-подтверждение"
              >
                📎 пруф
              </a>
            )}
          </div>
        </article>
      ))
    }
    <div id="empty-state" class="text-center py-[60px] px-5 text-text-dim" style="display: none;">
      <div id="empty-icon" class="text-[3.5em] mb-3.5" role="img" aria-label="Ангел">😇</div>
      <p>Ничего не найдено.</p>
    </div>
  </main>

  <script>
    const searchInput = document.getElementById("search") as HTMLInputElement;
    const entriesElements = document.querySelectorAll(".entry") as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById("empty-state");
    const counter = document.getElementById("counter");

    function applySearch() {
      const q = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;
      let visiblePeople = new Set();

      entriesElements.forEach(el => {
        const searchableData = JSON.parse(el.dataset.searchable || "{}");
        const matches =
          !q ||
          searchableData.telegram.includes(q) ||
          searchableData.description.includes(q) ||
          searchableData.quote.includes(q);

        if (matches) {
          el.style.display = "";
          visibleCount++;
          visiblePeople.add(searchableData.telegram);
        } else {
          el.style.display = "none";
        }
      });

      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? "block" : "none";
      }

      if (counter) {
        if (visibleCount === 0 && q) {
          counter.innerHTML = "";
        } else {
          counter.innerHTML = `<strong class="text-accent text-lg">${visibleCount}</strong> позорных записей · <strong class="text-accent text-lg">${visiblePeople.size}</strong> уникальных авторов`;
        }
      }
    }

    searchInput?.addEventListener("input", applySearch);
  </script>
</Layout>
